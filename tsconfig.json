{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./src",  // ⬅️ MUDAR DE VOLTA PARA "./src"
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": ["src/**/*"],  // ⬅️ INCLUIR APENAS O CÓDIGO FONTE
  "exclude": [
    "node_modules",
    "dist",
    "prisma.config.ts" // ⬅️ EXCLUIR ARQUIVOS DE CONFIGURAÇÃO DA RAIZ
  ]
}